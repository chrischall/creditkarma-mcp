{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "creditkarma-mcp",
  "owner": {
    "name": "Chris Hall",
    "email": "chris.c.hall@gmail.com"
  },
  "metadata": {
    "description": "MCP server for Credit Karma — natural-language access to your transactions, spending, and accounts",
    "version": "1.0.5"
  },
  "plugins": [
    {
      "name": "creditkarma-mcp",
      "source": {
        "source": "npm",
        "package": "creditkarma-mcp",
        "version": "1.0.5"
      },
      "description": "MCP server for Credit Karma — sync and query your transactions, spending, and accounts via natural language",
      "version": "1.0.5",
      "author": {
        "name": "Chris Hall"
      },
      "homepage": "https://github.com/chrischall/creditkarma-mcp",
      "repository": "https://github.com/chrischall/creditkarma-mcp",
      "license": "MIT",
      "keywords": ["credit-karma", "finance", "transactions", "mcp", "spending"],
      "category": "finance",
      "mcpServers": {
        "creditkarma": {
          "command": "npx",
          "args": ["creditkarma-mcp"],
          "env": {
            "CK_COOKIES": "${CK_COOKIES}"
          }
        }
      }
    }
  ]
}
