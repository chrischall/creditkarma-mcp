{
  "name": "creditkarma-mcp",
  "version": "1.0.2",
  "description": "MCP server for Credit Karma — natural-language access to your transactions, spending, and accounts",
  "author": "Claude Sonnet 4.6 (AI) <https://www.anthropic.com/claude>",
  "repository": {
    "type": "git",
    "url": "https://github.com/chrischall/creditkarma-mcp"
  },
  "type": "module",
  "bin": {
    "creditkarma-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "src/transaction.graphql"
  ],
  "scripts": {
    "build": "tsc && cp src/transaction.graphql dist/",
    "start": "node dist/index.js",
    "dev": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
