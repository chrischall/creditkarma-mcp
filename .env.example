CK_COOKIES=   # Optional. Leave blank to use the fetchproxy 0.3.0 extension fallback — sign into creditkarma.com once and the MCP reads CKAT + CKTRKID cookies automatically. Otherwise paste the Cookie header from DevTools.
CK_DISABLE_FETCHPROXY=   # Optional. Set to 1 to skip the fetchproxy fallback (headless / CI).
CK_DB_PATH=   # Optional: custom path for SQLite DB (default: ~/.creditkarma-mcp/transactions.db)
